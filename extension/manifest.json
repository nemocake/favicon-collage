{
  "manifest_version": 3,
  "name": "Favicon Collage",
  "version": "1.0.0",
  "description": "Turn your browser history into a favicon collage. Everything stays on your machine and nothing is uploaded.",
  "permissions": ["history", "favicon", "storage"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Make a favicon collage" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
